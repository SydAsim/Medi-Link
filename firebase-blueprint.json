{
  "entities": {
    "TriageReport": {
      "title": "Triage Report",
      "description": "A medical triage interaction recorded by a villager.",
      "type": "object",
      "properties": {
        "symptoms": { "type": "string", "description": "Original transcription of symptoms" },
        "translatedSummary": { "type": "string", "description": "AI-generated English summary" },
        "urgencyLevel": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "firstSteps": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "description": "Language code (ur, ps, en)" },
        "latitude": { "type": "number", "nullable": true },
        "longitude": { "type": "number", "nullable": true },
        "locationName": { "type": "string", "nullable": true },
        "phoneNumber": { "type": "string", "nullable": true, "description": "Optional contact number of the reporter" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symptoms", "translatedSummary", "urgencyLevel", "firstSteps", "language", "createdAt"]
    },
    "Clinic": {
      "title": "Clinic",
      "description": "Information about a healthcare facility.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "city": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" }
      },
      "required": ["name", "city", "latitude", "longitude"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "TriageReport",
      "description": "Collection of triage interactions."
    },
    "/clinics/{clinicId}": {
      "schema": "Clinic",
      "description": "Collection of healthcare facilities."
    }
  }
}
